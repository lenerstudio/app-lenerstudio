# CONFIGURACIÓN OPTIMIZADA POR ANTIGRAVITY PARA HOSTINGER
# Esta configuración asegura que las rutas de Next.js funcionen correctamente

# 1. Habilitar el motor de reescritura
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 2. Forzar HTTPS (Opcional, pero recomendado)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 3. No listar directorios por seguridad
    Options -Indexes

    # 4. Redirigir todas las peticiones a la App de Node.js
    # Nota: Si usas el selector de Node.js de Hostinger, el sistema se encarga 
    # internamente del proxy. Este .htaccess solo sirve para evitar conflictos.
    
    # Prevenir que Apache intente servir el archivo .next directamente
    RewriteRule ^\.next/ - [F,L]
    
    # Ignorar archivos estáticos reales (imágenes, css en public/)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^(.*)$ - [L]

</IfModule>

# Configuración de compresión (Hace que la web cargue más rápido)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>
